<div class="detail-page">
  <% if (page.cover){ %>
    <img src="<%- url_for(page.cover) %>" class="detail-media" alt="<%= page.title %>">
  <% } else { %>
    <div class="detail-media" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
  <% } %>
  <div class="detail-author-bar">
    <div class="detail-author-info">
      <div class="detail-avatar"></div>
      <span class="detail-author-name">珠稀翡翠珠宝</span>
    </div>
    <button class="detail-follow-btn">+ 关注</button>
  </div>
  <div class="detail-content">
    <%- page.content %>
  </div>
  <div class="comment-area collapsed">
    <div class="comment-toggle">查看全部评论 ▶</div>
  </div>
  <div class="related-posts">
  </div>
</div>

<div class="detail-bottom-bar">
  <a class="bottom-action" data-action="like">
    <span class="bottom-action-icon">🤍</span>
    <span class="bottom-action-text">点赞</span>
  </a>
  <a class="bottom-action" data-action="collect">
    <span class="bottom-action-icon">⭐</span>
    <span class="bottom-action-text">收藏</span>
  </a>
  <a class="bottom-action" data-action="share">
    <span class="bottom-action-icon">↗️</span>
    <span class="bottom-action-text">分享</span>
  </a>
  <a class="bottom-action" data-action="comment">
    <span class="bottom-action-icon">💬</span>
    <span class="bottom-action-text">评论</span>
  </a>
</div>
